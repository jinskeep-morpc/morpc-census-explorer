# Census Bureau API key — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# PostgreSQL password for the PostGIS container
DB_PASSWORD=changeme

# Set automatically by Podman Compose; override here for local dev
DATABASE_URL=postgresql://morpc:changeme@localhost:5432/morpc_census

# Directory where exported files are written (created if it doesn't exist)
EXPORT_DIR=./exports
